#!/usr/bin/env bash

set -euo pipefail

DEFAULT_DOTFILES_DIR="$HOME/.dotfiles"
DEFAULT_DOTFILES_REPO_URL="https://github.com/yehogwon/dotfiles"

DOTFILES_DIR=""
DOTFILES_REPO_URL="${DOTFILES_REPO_URL:-$DEFAULT_DOTFILES_REPO_URL}"
BOOTSTRAP_CLONED=0

log() {
    echo "$*"
}

step() {
    log "[info] $*"
}

run_quiet() {
    "$@" >/dev/null 2>&1
}

prompt_yes_no() {
    local question="$1"
    local default_answer="${2:-n}"
    local prompt_suffix
    local default_label
    local answer=""

    if [[ "$default_answer" == "y" ]]; then
        prompt_suffix="[Y/n]"
        default_label="yes"
    else
        prompt_suffix="[y/N]"
        default_label="no"
    fi

    while true; do
        if [[ -t 0 ]]; then
            printf "%s %s (default: %s) " "$question" "$prompt_suffix" "$default_label"
            if ! IFS= read -r answer; then
                return 1
            fi
        elif [[ -t 1 ]]; then
            printf "%s %s (default: %s) " "$question" "$prompt_suffix" "$default_label" > /dev/tty
            if ! IFS= read -r answer < /dev/tty 2>/dev/null; then
                return 1
            fi
        else
            return 1
        fi

        answer="${answer:-$default_answer}"

        case "$answer" in
            y|Y|yes|YES|Yes)
                return 0
                ;;
            n|N|no|NO|No)
                return 1
                ;;
            *)
                log "[warn] please answer yes or no"
                ;;
        esac
    done
}

cleanup_bootstrap_checkout_on_failure() {
    local exit_code=$?

    if [[ "$exit_code" -ne 0 && "$BOOTSTRAP_CLONED" -eq 1 && -d "$DEFAULT_DOTFILES_DIR" ]]; then
        log "[info] removing failed checkout at $DEFAULT_DOTFILES_DIR"
        rm -rf "$DEFAULT_DOTFILES_DIR" || true
    fi
}

trap 'cleanup_bootstrap_checkout_on_failure' EXIT

detect_repo_from_script_path() {
    local source_path="${BASH_SOURCE[0]:-}"
    local script_dir
    local dotfile_root

    [[ -n "$source_path" ]] || return 1

    case "$source_path" in
        /dev/fd/*|/dev/stdin|-)
            return 1
            ;;
    esac

    [[ -e "$source_path" ]] || return 1

    script_dir="$(cd -- "$(dirname -- "$source_path")" && pwd -P)"
    dotfile_root="$(cd -- "$script_dir/.." && pwd -P)"

    log "[info] using current checkout: $dotfile_root"
    DOTFILES_DIR="$dotfile_root"
    return 0
}

ensure_checkout() {
    local repo_url="$1"
    local fzf_installer

    if ! command -v git >/dev/null 2>&1; then
        log "[error] git is required"
        exit 1
    fi

    if [[ -e "$DEFAULT_DOTFILES_DIR" ]]; then
        log "[error] $DEFAULT_DOTFILES_DIR already exists"
        log "[hint] remove it first or run this script from an existing dotfiles checkout"
        exit 1
    fi

    BOOTSTRAP_CLONED=1

    log "[info] cloning dotfiles into $DEFAULT_DOTFILES_DIR"
    if ! run_quiet git clone --recurse-submodules "$repo_url" "$DEFAULT_DOTFILES_DIR"; then
        log "[error] failed to clone dotfiles"
        exit 1
    fi

    fzf_installer="$DEFAULT_DOTFILES_DIR/modules/fzf/install"
    if [[ ! -f "$fzf_installer" ]]; then
        log "[error] fzf installer not found at $fzf_installer"
        exit 1
    fi

    log "[info] installing fzf binary"
    if ! run_quiet bash "$fzf_installer" --bin; then
        log "[error] failed to install fzf binary"
        exit 1
    fi

    DOTFILES_DIR="$DEFAULT_DOTFILES_DIR"
}

resolve_dotfiles_dir() {
    if detect_repo_from_script_path; then
        DOTFILES_DIR="$(cd -- "$DOTFILES_DIR" && pwd -P)"
        return 0
    fi

    ensure_checkout "$DOTFILES_REPO_URL"
    DOTFILES_DIR="$(cd -- "$DOTFILES_DIR" && pwd -P)"
}

install_homebrew() {
    local brew_root="$HOME/.linuxbrew"
    local brew_repo="$brew_root/Homebrew"
    local brew_bin_dir="$brew_root/bin"
    local brew_bin="$brew_bin_dir/brew"

    step "installing Homebrew"

    if ! command -v git >/dev/null 2>&1; then
        log "[error] git is required to install Homebrew"
        exit 1
    fi

    if [[ -e "$brew_root" && ! -d "$brew_root" ]]; then
        log "[error] $brew_root exists but is not a directory"
        exit 1
    fi

    mkdir -p "$brew_root"

    if [[ -d "$brew_repo/.git" ]]; then
        log "[info] Homebrew repository already exists at $brew_repo"
    elif [[ -e "$brew_repo" ]]; then
        log "[error] $brew_repo exists and is not a git checkout"
        exit 1
    else
        if ! run_quiet git clone https://github.com/Homebrew/brew "$brew_repo"; then
            log "[error] failed to clone Homebrew"
            exit 1
        fi
    fi

    mkdir -p "$brew_bin_dir"
    ln -sfn "$brew_repo/bin/brew" "$brew_bin"

    if ! run_quiet "$brew_bin" analytics off; then
        log "[error] failed to disable Homebrew analytics"
        exit 1
    fi

    if ! run_quiet "$brew_bin" update -fq; then
        log "[error] failed to update Homebrew"
        exit 1
    fi

    if ! run_quiet "$brew_bin" install portable-ruby gcc; then
        log "[error] failed to install Homebrew packages"
        exit 1
    fi

    log "[ok] Homebrew installed at $brew_root"
}

is_linux_platform() {
    [[ "$(uname -s)" == "Linux" ]]
}

append_block() {
    local file="$1"
    local begin_marker="$2"
    local end_marker="$3"
    local payload="$4"
    local label="$5"
    local begin_count
    local end_count
    local tmp_file

    step "configuring $label"

    mkdir -p "$(dirname "$file")"
    touch "$file"

    begin_count="$(grep -Fxc "$begin_marker" "$file" || true)"
    end_count="$(grep -Fxc "$end_marker" "$file" || true)"

    if [[ "$begin_count" -ne "$end_count" ]]; then
        log "[warn] $label has mismatched markers; skipping"
        return 0
    fi

    if [[ "$begin_count" -gt 0 ]]; then
        tmp_file="$(mktemp)"

        awk -v begin_marker="$begin_marker" -v end_marker="$end_marker" '
            $0 == begin_marker {skip = 1; next}
            $0 == end_marker {skip = 0; next}
            !skip {print}
        ' "$file" > "$tmp_file"

        mv "$tmp_file" "$file"
        log "[info] refreshed existing $label block"
    fi

    {
        log "$begin_marker"
        while IFS= read -r line; do
            log "$line"
        done <<< "$payload"
        log "$end_marker"
    } >> "$file"

    log "[ok] $label configured"
}

SHELL_BEGIN="# >>> dotfiles >>>"
SHELL_END="# <<< dotfiles <<<"
VIM_BEGIN="\" >>> dotfiles >>>"
VIM_END="\" <<< dotfiles <<<"
GIT_BEGIN="; >>> dotfiles >>>"
GIT_END="; <<< dotfiles <<<"

step "starting dotfiles installation"
resolve_dotfiles_dir
log "[info] dotfiles path: $DOTFILES_DIR"
step "updating shell and tool configuration files"

append_block "$HOME/.bashrc" "$SHELL_BEGIN" "$SHELL_END" "[ -f \"$DOTFILES_DIR/shell/bash/bashrc\" ] && source \"$DOTFILES_DIR/shell/bash/bashrc\"" ".bashrc"
append_block "$HOME/.bash_profile" "$SHELL_BEGIN" "$SHELL_END" "[ -f \"$DOTFILES_DIR/shell/bash/bash_profile\" ] && source \"$DOTFILES_DIR/shell/bash/bash_profile\"" ".bash_profile"
append_block "$HOME/.inputrc" "$SHELL_BEGIN" "$SHELL_END" "\$include $DOTFILES_DIR/shell/bash/inputrc" ".inputrc"

append_block "$HOME/.zshrc" "$SHELL_BEGIN" "$SHELL_END" "[ -f \"$DOTFILES_DIR/shell/zsh/zshrc\" ] && source \"$DOTFILES_DIR/shell/zsh/zshrc\"" ".zshrc"
append_block "$HOME/.zprofile" "$SHELL_BEGIN" "$SHELL_END" "[ -f \"$DOTFILES_DIR/shell/zsh/zprofile\" ] && source \"$DOTFILES_DIR/shell/zsh/zprofile\"" ".zprofile"
append_block "$HOME/.zlogin" "$SHELL_BEGIN" "$SHELL_END" "[ -f \"$DOTFILES_DIR/shell/zsh/zlogin\" ] && source \"$DOTFILES_DIR/shell/zsh/zlogin\"" ".zlogin"
append_block "$HOME/.zlogout" "$SHELL_BEGIN" "$SHELL_END" "[ -f \"$DOTFILES_DIR/shell/zsh/zlogout\" ] && source \"$DOTFILES_DIR/shell/zsh/zlogout\"" ".zlogout"
append_block "$HOME/.zshenv" "$SHELL_BEGIN" "$SHELL_END" "[ -f \"$DOTFILES_DIR/shell/zsh/zshenv\" ] && source \"$DOTFILES_DIR/shell/zsh/zshenv\"" ".zshenv"

append_block "$HOME/.vimrc" "$VIM_BEGIN" "$VIM_END" "if filereadable(expand(\"$DOTFILES_DIR/vim/vimrc\")) | execute \"source \" . fnameescape(expand(\"$DOTFILES_DIR/vim/vimrc\")) | endif" ".vimrc"

git_payload="[include]
    path = \"$DOTFILES_DIR/git/gitconfig\""
append_block "$HOME/.gitconfig" "$GIT_BEGIN" "$GIT_END" "$git_payload" ".gitconfig"

append_block "$HOME/.tmux.conf" "$SHELL_BEGIN" "$SHELL_END" "if-shell \"[ -f '$DOTFILES_DIR/tmux/tmux.conf' ]\" \"source-file '$DOTFILES_DIR/tmux/tmux.conf'\"" ".tmux.conf"

if is_linux_platform; then
    step "optional Homebrew installation"
    if prompt_yes_no "Install Homebrew in ~/.linuxbrew?" "n"; then
        install_homebrew
    else
        log "[skip] Homebrew installation skipped"
    fi

    log "[hint] remove Homebrew anytime by deleting ~/.linuxbrew"
fi

log "Done. Restart your shell (or source your rc file) to apply changes."
