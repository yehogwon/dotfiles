#!/usr/bin/env bash

set -euo pipefail

DEFAULT_DOTFILES_DIR="$HOME/.dotfiles"
DEFAULT_DOTFILES_REPO_URL="https://github.com/yehogwon/dotfiles"
HOMEBREW_INSTALL_URL="https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh"

DOTFILES_DIR=""
DOTFILES_REPO_URL="${DOTFILES_REPO_URL:-$DEFAULT_DOTFILES_REPO_URL}"
BOOTSTRAP_CLONED=0

log() {
    echo "$*"
}

run_quiet() {
    "$@" >/dev/null 2>&1
}

prompt_yes_no() {
    local question="$1"
    local default_answer="${2:-n}"
    local prompt_suffix
    local answer=""

    if [[ "$default_answer" == "y" ]]; then
        prompt_suffix="[Y/n]"
    else
        prompt_suffix="[y/N]"
    fi

    while true; do
        if [[ -t 0 ]]; then
            printf "%s %s " "$question" "$prompt_suffix"
            if ! IFS= read -r answer; then
                return 1
            fi
        elif [[ -t 1 ]]; then
            printf "%s %s " "$question" "$prompt_suffix" > /dev/tty
            if ! IFS= read -r answer < /dev/tty 2>/dev/null; then
                return 1
            fi
        else
            return 1
        fi

        answer="${answer:-$default_answer}"

        case "$answer" in
            y|Y|yes|YES|Yes)
                return 0
                ;;
            n|N|no|NO|No)
                return 1
                ;;
            *)
                log "[warn] please answer yes or no"
                ;;
        esac
    done
}

maybe_install_homebrew() {
    if command -v brew >/dev/null 2>&1; then
        log "[skip] homebrew already installed"
        return 0
    fi

    if ! prompt_yes_no "Install Homebrew?" "n"; then
        log "[skip] homebrew installation skipped"
        return 0
    fi

    if ! command -v curl >/dev/null 2>&1; then
        log "[warn] curl is required to install homebrew"
        return 0
    fi

    log "[info] installing homebrew"
    if curl -fsSL "$HOMEBREW_INSTALL_URL" 2>/dev/null | NONINTERACTIVE=1 /bin/bash >/dev/null 2>&1; then
        log "[ok] homebrew installed"
        return 0
    fi

    log "[warn] failed to install homebrew"
    return 0
}

cleanup_bootstrap_checkout_on_failure() {
    local exit_code=$?

    if [[ "$exit_code" -ne 0 && "$BOOTSTRAP_CLONED" -eq 1 && -d "$DEFAULT_DOTFILES_DIR" ]]; then
        log "[info] removing failed checkout at $DEFAULT_DOTFILES_DIR"
        rm -rf "$DEFAULT_DOTFILES_DIR" || true
    fi
}

trap 'cleanup_bootstrap_checkout_on_failure' EXIT

detect_repo_from_script_path() {
    local source_path="${BASH_SOURCE[0]:-}"
    local script_dir
    local dotfile_root

    [[ -n "$source_path" ]] || return 1

    case "$source_path" in
        /dev/fd/*|/dev/stdin|-)
            return 1
            ;;
    esac

    [[ -e "$source_path" ]] || return 1

    script_dir="$(cd -- "$(dirname -- "$source_path")" && pwd -P)"
    dotfile_root="$(cd -- "$script_dir/.." && pwd -P)"

    log "[info] using current checkout: $dotfile_root"
    DOTFILES_DIR="$dotfile_root"
    return 0
}

ensure_checkout() {
    local repo_url="$1"
    local fzf_installer

    if ! command -v git >/dev/null 2>&1; then
        log "[error] git is required"
        exit 1
    fi

    if [[ -e "$DEFAULT_DOTFILES_DIR" ]]; then
        log "[error] $DEFAULT_DOTFILES_DIR already exists"
        log "[hint] remove it first or run this script from an existing dotfiles checkout"
        exit 1
    fi

    BOOTSTRAP_CLONED=1

    log "[info] cloning dotfiles into $DEFAULT_DOTFILES_DIR"
    if ! run_quiet git clone --recurse-submodules "$repo_url" "$DEFAULT_DOTFILES_DIR"; then
        log "[error] failed to clone dotfiles"
        exit 1
    fi

    fzf_installer="$DEFAULT_DOTFILES_DIR/modules/fzf/install"
    if [[ ! -f "$fzf_installer" ]]; then
        log "[error] fzf installer not found at $fzf_installer"
        exit 1
    fi

    log "[info] installing fzf binary"
    if ! run_quiet bash "$fzf_installer" --bin; then
        log "[error] failed to install fzf binary"
        exit 1
    fi

    DOTFILES_DIR="$DEFAULT_DOTFILES_DIR"
}

resolve_dotfiles_dir() {
    if detect_repo_from_script_path; then
        DOTFILES_DIR="$(cd -- "$DOTFILES_DIR" && pwd -P)"
        return 0
    fi

    ensure_checkout "$DOTFILES_REPO_URL"
    DOTFILES_DIR="$(cd -- "$DOTFILES_DIR" && pwd -P)"
}

append_block() {
    local file="$1"
    local begin_marker="$2"
    local end_marker="$3"
    local payload="$4"
    local label="$5"

    mkdir -p "$(dirname "$file")"
    touch "$file"

    if grep -Fqx "$begin_marker" "$file"; then
        log "[skip] $label already configured"
        return 0
    fi

    {
        log ""
        log "$begin_marker"
        while IFS= read -r line; do
            log "$line"
        done <<< "$payload"
        log "$end_marker"
    } >> "$file"

    log "[ok] $label configured"
}

SHELL_BEGIN="# >>> dotfiles >>>"
SHELL_END="# <<< dotfiles <<<"
VIM_BEGIN="\" >>> dotfiles >>>"
VIM_END="\" <<< dotfiles <<<"
GIT_BEGIN="; >>> dotfiles >>>"
GIT_END="; <<< dotfiles <<<"

resolve_dotfiles_dir
log "[info] dotfiles path: $DOTFILES_DIR"

append_block "$HOME/.bashrc" "$SHELL_BEGIN" "$SHELL_END" "source \"$DOTFILES_DIR/shell/bash/bashrc\"" ".bashrc"
append_block "$HOME/.bash_profile" "$SHELL_BEGIN" "$SHELL_END" "source \"$DOTFILES_DIR/shell/bash/bash_profile\"" ".bash_profile"
append_block "$HOME/.inputrc" "$SHELL_BEGIN" "$SHELL_END" "\$include $DOTFILES_DIR/shell/bash/inputrc" ".inputrc"

append_block "$HOME/.zshrc" "$SHELL_BEGIN" "$SHELL_END" "source \"$DOTFILES_DIR/shell/zsh/zshrc\"" ".zshrc"
append_block "$HOME/.zprofile" "$SHELL_BEGIN" "$SHELL_END" "source \"$DOTFILES_DIR/shell/zsh/zprofile\"" ".zprofile"
append_block "$HOME/.zlogin" "$SHELL_BEGIN" "$SHELL_END" "source \"$DOTFILES_DIR/shell/zsh/zlogin\"" ".zlogin"
append_block "$HOME/.zlogout" "$SHELL_BEGIN" "$SHELL_END" "source \"$DOTFILES_DIR/shell/zsh/zlogout\"" ".zlogout"
append_block "$HOME/.zshenv" "$SHELL_BEGIN" "$SHELL_END" "source \"$DOTFILES_DIR/shell/zsh/zshenv\"" ".zshenv"

append_block "$HOME/.vimrc" "$VIM_BEGIN" "$VIM_END" "source $DOTFILES_DIR/vim/vimrc" ".vimrc"

git_payload="[include]
    path = \"$DOTFILES_DIR/git/gitconfig\""
append_block "$HOME/.gitconfig" "$GIT_BEGIN" "$GIT_END" "$git_payload" ".gitconfig"

append_block "$HOME/.tmux.conf" "$SHELL_BEGIN" "$SHELL_END" "source-file \"$DOTFILES_DIR/tmux/tmux.conf\"" ".tmux.conf"

maybe_install_homebrew

log "Done. Restart your shell (or source your rc file) to apply changes."
