#!/usr/bin/env bash

target_rc="${1:-}"

if [ -z "$target_rc" ]; then
  printf "usage: source bin/shellenv <rc-name>\n" >&2
  return 1 2>/dev/null || exit 1
fi

if [ -n "${ZSH_VERSION:-}" ]; then
  eval 'shellenv_source="${(%):-%x}"'
else
  shellenv_source="${BASH_SOURCE[0]:-$0}"
fi

case "$shellenv_source" in
  /*) ;;
  *) shellenv_source="$PWD/$shellenv_source" ;;
esac

DOTFILES_HOME="${shellenv_source%/*}"
DOTFILES_HOME="${DOTFILES_HOME%/bin}"
export DOTFILES_HOME

unset shellenv_source

case "$target_rc" in
  bashrc)
    source "$DOTFILES_HOME/shell/bash/bashrc"
    ;;
  bash_profile)
    source "$DOTFILES_HOME/shell/bash/bash_profile"
    ;;
  zshrc)
    source "$DOTFILES_HOME/shell/zsh/zshrc"
    ;;
  zprofile)
    source "$DOTFILES_HOME/shell/zsh/zprofile"
    ;;
  zlogin)
    source "$DOTFILES_HOME/shell/zsh/zlogin"
    ;;
  zlogout)
    source "$DOTFILES_HOME/shell/zsh/zlogout"
    ;;
  zshenv)
    source "$DOTFILES_HOME/shell/zsh/zshenv"
    ;;
  *)
    printf "unknown shell rc name: %s\n" "$target_rc" >&2
    return 1 2>/dev/null || exit 1
    ;;
esac
