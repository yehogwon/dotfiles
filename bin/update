#!/usr/bin/env bash

set -euo pipefail

PERMISSIONS_MANIFEST_NAME=".permissions"

log() {
    printf "%s\n" "$*"
}

step() {
    log "[info] $*"
}

is_git_worktree() {
    local dir="$1"

    git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1
}

contains_parent_traversal() {
    local path="$1"

    [[ "/$path/" == *"/../"* ]]
}

is_valid_permission_mode() {
    local mode="$1"

    [[ "$mode" =~ ^[0-7]{3,4}$ ]]
}

is_within_dir() {
    local path="$1"
    local root_dir="$2"

    [[ "$path" == "$root_dir" || "$path" == "$root_dir"/* ]]
}

resolve_permissions_repo_path() {
    local repo_root="$1"
    local path="$2"

    [[ "$path" != /* ]] || return 1
    contains_parent_traversal "$path" && return 1

    printf '%s\n' "$repo_root/$path"
}

enforce_permissions_manifest() {
    local repo_root="$1"
    local manifest_name="${2:-.permissions}"
    local manifest_path="$repo_root/$manifest_name"
    local repo_root_real
    local line=""
    local line_number=0
    local entry_mode
    local entry_path
    local extra
    local target_path
    local target_path_real

    if [[ ! -f "$manifest_path" ]]; then
        log "[skip] permissions manifest not found at $manifest_path"
        return 0
    fi

    repo_root_real="$(realpath "$repo_root")"

    step "applying managed permissions"

    while IFS= read -r line || [[ -n "$line" ]]; do
        line_number=$((line_number + 1))

        [[ "$line" =~ ^[[:space:]]*$ ]] && continue
        [[ "$line" =~ ^[[:space:]]*# ]] && continue

        read -r entry_mode entry_path extra <<< "$line"

        if [[ -n "$extra" || -z "$entry_mode" || -z "$entry_path" ]]; then
            log "[error] invalid permissions entry at $manifest_path:$line_number"
            exit 1
        fi

        if ! is_valid_permission_mode "$entry_mode"; then
            log "[error] invalid mode at $manifest_path:$line_number: $entry_mode"
            exit 1
        fi

        target_path="$(resolve_permissions_repo_path "$repo_root" "$entry_path" || true)"
        if [[ -z "$target_path" ]]; then
            log "[error] invalid managed path at $manifest_path:$line_number: $entry_path"
            exit 1
        fi

        if [[ ! -e "$target_path" ]]; then
            log "[error] managed path not found at $manifest_path:$line_number: $entry_path"
            exit 1
        fi

        if [[ -L "$target_path" ]]; then
            log "[error] symlink targets are not allowed at $manifest_path:$line_number: $entry_path"
            exit 1
        fi

        if [[ ! -f "$target_path" && ! -d "$target_path" ]]; then
            log "[error] managed path must be a regular file or directory at $manifest_path:$line_number: $entry_path"
            exit 1
        fi

        target_path_real="$(realpath "$target_path")"
        if ! is_within_dir "$target_path_real" "$repo_root_real"; then
            log "[error] managed path escapes DOTFILES_DIR at $manifest_path:$line_number: $entry_path"
            exit 1
        fi

        chmod "$entry_mode" "$target_path"
        log "[ok] enforced $entry_mode on $entry_path"
    done < "$manifest_path"
}

resolve_dotfiles_home() {
    if [[ -z "${DOTFILES_HOME:-}" ]]; then
        log "[error] DOTFILES_HOME is not set"
        log "[hint] dotfiles is not set up yet, so there is nothing to update"
        exit 1
    fi

    if [[ ! -d "$DOTFILES_HOME" ]]; then
        log "[error] DOTFILES_HOME path not found: $DOTFILES_HOME"
        exit 1
    fi

    DOTFILES_HOME="$(realpath "$DOTFILES_HOME")"

    if ! is_git_worktree "$DOTFILES_HOME"; then
        log "[error] DOTFILES_HOME is not a git checkout: $DOTFILES_HOME"
        exit 1
    fi
}

step "starting dotfiles update"

if ! command -v git >/dev/null 2>&1; then
    log "[error] git is required"
    exit 1
fi

resolve_dotfiles_home
log "[info] dotfiles path: $DOTFILES_HOME"

step "pulling latest changes"
if ! git -C "$DOTFILES_HOME" pull; then
    log "[error] failed to pull latest changes"
    exit 1
fi

step "updating submodules"
if ! git -C "$DOTFILES_HOME" submodule update --init --recursive; then
    log "[error] failed to update submodules"
    exit 1
fi

enforce_permissions_manifest "$DOTFILES_HOME" "$PERMISSIONS_MANIFEST_NAME"

log "[ok] dotfiles update complete"
