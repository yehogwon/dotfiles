#!/usr/bin/env bash

set -euo pipefail

NONINTERACTIVE_DOTFILES="${NONINTERACTIVE_DOTFILES:-0}"

log() {
    printf "%s\n" "$*"
}

step() {
    log "[info] $*"
}

ensure_trailing_newline() {
    local file="$1"

    if [[ -s "$file" && -n "$(tail -c 1 "$file" 2>/dev/null)" ]]; then
        printf '\n' >> "$file"
    fi
}

strip_managed_block() {
    local input_file="$1"
    local output_file="$2"
    local begin_marker="$3"
    local end_marker="$4"

    awk -v begin_marker="$begin_marker" -v end_marker="$end_marker" '
        $0 == begin_marker {skip = 1; next}
        $0 == end_marker {skip = 0; trim_blank = 1; next}
        trim_blank && $0 == "" {trim_blank = 0; next}
        !skip {trim_blank = 0; print}
    ' "$input_file" > "$output_file"
}

prompt_yes_no() {
    local question="$1"
    local default_answer="${2:-n}"
    local env_var_name="${3:-}"
    local prompt_suffix
    local default_label
    local env_var_value=""
    local answer=""

    if [[ -n "$env_var_name" ]]; then
        env_var_value="${!env_var_name:-}"

        case "$env_var_value" in
            y|Y|yes|YES|Yes|1|true|TRUE|True)
                return 0
                ;;
            n|N|no|NO|No|0|false|FALSE|False)
                return 1
                ;;
            "")
                ;;
            *)
                log "[warn] invalid value for $env_var_name: $env_var_value"
                ;;
        esac
    fi

    if [[ "$default_answer" == "y" ]]; then
        prompt_suffix="[Y/n]"
        default_label="yes"
    else
        prompt_suffix="[y/N]"
        default_label="no"
    fi

    while true; do
        if [[ "$NONINTERACTIVE_DOTFILES" == "1" ]]; then
            answer="$default_answer"
        elif [[ -t 0 ]]; then
            printf "%s %s (default: %s) " "$question" "$prompt_suffix" "$default_label"
            if ! IFS= read -r answer; then
                return 1
            fi
        elif [[ -t 1 ]]; then
            printf "%s %s (default: %s) " "$question" "$prompt_suffix" "$default_label" > /dev/tty
            if ! IFS= read -r answer < /dev/tty 2>/dev/null; then
                return 1
            fi
        else
            return 1
        fi

        answer="${answer:-$default_answer}"

        case "$answer" in
            y|Y|yes|YES|Yes)
                return 0
                ;;
            n|N|no|NO|No)
                return 1
                ;;
            *)
                log "[warn] please answer yes or no"
                ;;
        esac
    done
}

remove_block() {
    local file="$1"
    local begin_marker="$2"
    local end_marker="$3"
    local label="$4"

    step "checking $label"

    if [[ ! -f "$file" ]]; then
        log "[skip] $label not found"
        return 0
    fi

    local begin_count
    local end_count
    begin_count="$(grep -Fxc "$begin_marker" "$file" || true)"
    end_count="$(grep -Fxc "$end_marker" "$file" || true)"

    if [[ "$begin_count" -eq 0 && "$end_count" -eq 0 ]]; then
        log "[skip] $label not configured"
        return 0
    fi

    if [[ "$begin_count" -ne "$end_count" ]]; then
        log "[warn] $label has mismatched markers; skipping"
        return 0
    fi

    local tmp_file
    tmp_file="$(mktemp)"

    strip_managed_block "$file" "$tmp_file" "$begin_marker" "$end_marker"

    mv "$tmp_file" "$file"
    ensure_trailing_newline "$file"
    log "[ok] removed $label block"
}

resolve_checkout_from_script_path() {
    local source_path="${BASH_SOURCE[0]:-}"
    local script_dir
    local checkout_dir

    [[ -n "$source_path" ]] || return 1

    case "$source_path" in
        /dev/fd/*|/dev/stdin|-)
            return 1
            ;;
    esac

    [[ -e "$source_path" ]] || return 1

    script_dir="$(cd -- "$(dirname -- "$source_path")" && pwd -P)"
    checkout_dir="$(cd -- "$script_dir/.." && pwd -P)"

    printf "%s\n" "$checkout_dir"
}

is_checkout_dir_safe_to_remove() {
    local checkout_dir="$1"
    local home_dir

    home_dir="$(cd -- "$HOME" && pwd -P)"

    [[ -n "$checkout_dir" ]] || return 1
    [[ "$checkout_dir" != "/" ]] || return 1
    [[ "$checkout_dir" != "$home_dir" ]] || return 1

    [[ -f "$checkout_dir/bin/install" ]] || return 1
    [[ -f "$checkout_dir/bin/uninstall" ]] || return 1
    [[ -f "$checkout_dir/shell/all" ]] || return 1
    [[ -f "$checkout_dir/git/gitconfig" ]] || return 1
    [[ -f "$checkout_dir/vim/vimrc" ]] || return 1
    [[ -f "$checkout_dir/tmux/tmux.conf" ]] || return 1

    return 0
}

remove_checkout_dir() {
    local checkout_dir=""

    checkout_dir="$(resolve_checkout_from_script_path || true)"
    if [[ -z "$checkout_dir" ]]; then
        log "[skip] could not detect checkout path; repo directory left in place"
        return 0
    fi

    if [[ ! -d "$checkout_dir" ]]; then
        log "[skip] checkout path not found: $checkout_dir"
        return 0
    fi

    if ! is_checkout_dir_safe_to_remove "$checkout_dir"; then
        log "[warn] refusing to remove unexpected path: $checkout_dir"
        return 0
    fi

    if ! prompt_yes_no "Remove dotfiles checkout directory at $checkout_dir?" "n" "REMOVE_DOTFILES_CHECKOUT"; then
        log "[skip] checkout directory removal skipped"
        return 0
    fi

    cd -- "$HOME"

    if rm -rf -- "$checkout_dir"; then
        log "[ok] removed checkout directory: $checkout_dir"
        return 0
    fi

    log "[warn] failed to remove checkout directory: $checkout_dir"
    return 0
}

SHELL_BEGIN="# >>> dotfiles >>>"
SHELL_END="# <<< dotfiles <<<"
VIM_BEGIN="\" >>> dotfiles >>>"
VIM_END="\" <<< dotfiles <<<"
GIT_BEGIN="; >>> dotfiles >>>"
GIT_END="; <<< dotfiles <<<"

step "starting dotfiles uninstallation"
log "[warn] this can remove your entire dotfiles checkout directory"
step "removing shell and tool configuration blocks"

remove_block "$HOME/.bashrc" "$SHELL_BEGIN" "$SHELL_END" ".bashrc"
remove_block "$HOME/.bash_profile" "$SHELL_BEGIN" "$SHELL_END" ".bash_profile"
remove_block "$HOME/.inputrc" "$SHELL_BEGIN" "$SHELL_END" ".inputrc"

remove_block "$HOME/.zshrc" "$SHELL_BEGIN" "$SHELL_END" ".zshrc"
remove_block "$HOME/.zprofile" "$SHELL_BEGIN" "$SHELL_END" ".zprofile"
remove_block "$HOME/.zlogin" "$SHELL_BEGIN" "$SHELL_END" ".zlogin"
remove_block "$HOME/.zlogout" "$SHELL_BEGIN" "$SHELL_END" ".zlogout"
remove_block "$HOME/.zshenv" "$SHELL_BEGIN" "$SHELL_END" ".zshenv"

remove_block "$HOME/.vimrc" "$VIM_BEGIN" "$VIM_END" ".vimrc"
remove_block "$HOME/.gitconfig" "$GIT_BEGIN" "$GIT_END" ".gitconfig"
remove_block "$HOME/.ssh/config" "$SHELL_BEGIN" "$SHELL_END" ".ssh/config"
remove_block "$HOME/.tmux.conf" "$SHELL_BEGIN" "$SHELL_END" ".tmux.conf"

step "removing checkout directory if this script is from a checkout"
remove_checkout_dir

log "[hint] remove Homebrew anytime by deleting ~/.linuxbrew"

log "Done. Restart your shell (or source your rc file) to apply changes."
